<?xml version="1.0" encoding="utf-8"?>
<!--
  Mute icon overlay — drawn over the caller's profile picture.
  Tapping it adds the incoming number to the silent list.
  Sized at 68dp to sit neatly inside a typical 80–100dp avatar circle.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="68dp"
    android:layout_height="68dp"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:background="@drawable/circle_overlay_bg"
        android:src="@drawable/ic_mute_overlay"
        android:padding="14dp"
        android:scaleType="fitCenter"
        android:contentDescription="Add to silent list" />

</FrameLayout>
