<?xml version="1.0" encoding="utf-8"?>
<!--
  Volume-button popup overlay — shown when the user presses volume-down to silence a ringing call.
  Positioned near the bottom of the screen, above the answer/decline buttons.
  Auto-dismisses after 10 seconds.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/overlay_dialog_bg"
    android:padding="18dp"
    android:elevation="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/overlay_add_prompt"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/overlay_add_subtitle"
        android:textColor="#AAAACC"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginBottom="14dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_no_thanks"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/overlay_no_thanks"
            android:textColor="#CCCCCC"
            android:backgroundTint="#3A3A55"
            android:layout_marginEnd="8dp"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

        <Button
            android:id="@+id/btn_yes_add"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/overlay_yes_add"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E53935" />

    </LinearLayout>

</LinearLayout>
